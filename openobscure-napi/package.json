{
  "name": "@openobscure/scanner-napi",
  "version": "0.1.0",
  "description": "OpenObscure native PII scanner \u2014 HybridScanner (regex + keywords + NER) via napi-rs",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "napi": {
    "name": "scanner",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "optionalDependencies": {
    "@openobscure/scanner-napi-darwin-arm64": "0.1.0",
    "@openobscure/scanner-napi-darwin-x64": "0.1.0",
    "@openobscure/scanner-napi-linux-x64-gnu": "0.1.0",
    "@openobscure/scanner-napi-linux-arm64-gnu": "0.1.0",
    "@openobscure/scanner-napi-linux-x64-musl": "0.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "scripts": {
    "build": "napi build --release",
    "build-debug": "napi build",
    "test": "node --test test.mjs",
    "postinstall": "node postinstall.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "postinstall.js",
    "test.mjs",
    "*.node",
    "models/"
  ]
}
