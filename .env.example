# OpenObscure Gateway — local environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# FPE master key (required). Generate with:
#   openobscure print-key
OPENOBSCURE_MASTER_KEY=<64-hex-chars>

# Auth token for the health endpoint. Used by L1 plugin heartbeat monitor.
# Change this in production.
OPENOBSCURE_AUTH_TOKEN=change-me-in-production
