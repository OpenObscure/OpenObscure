+    /// Format a concise warning banner to prepend to assistant message content
+    /// when the cognitive firewall detects manipulation patterns.
+    private func riWarningLabel(severity: String, categories: [String]) -> String {
+        let cats = categories.map { cat -> String in
+            switch cat {
+            case "Art_5_1_a_Deceptive": return "Deceptive Practices"
+            case "Art_5_1_b_Age":       return "Age-Based Targeting"
+            case "Art_5_1_b_SocioEcon": return "Socioeconomic Targeting"
+            case "Art_5_1_c_Social_Scoring": return "Social Scoring"
+            default:
+                return cat
+            }
+        }
+        let tactics = cats.isEmpty ? severity : cats.joined(separator: " • ")
+        switch severity {
+        case "Caution":
+            return "--- OpenObscure WARNING ---\nDetected: \(tactics)\nRecommendation: Pause and verify with objective evidence before acting.\n---\n\n"
+        case "Warning":
+            return "--- OpenObscure WARNING ---\nDetected: \(tactics)\nThis response contains language patterns associated with influence tactics.\n---\n\n"
+        default:
+            return "--- OpenObscure WARNING ---\nDetected: \(tactics)\n---\n\n"
+        }
+    }
