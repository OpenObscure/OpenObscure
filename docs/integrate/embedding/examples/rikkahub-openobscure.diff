+/**
+ * Restore FPE tokens in text for display, and prepend RI warning if flagged.
+ * Called at render time so the shared Conversation state always retains raw
+ * tokens (for LLM requests). Cached via `remember` so restore() and
+ * getRiWarning() are only called when text or riVersion changes.
+ *
+ * The riVersion key forces recomposition when setRiWarning() is called after
+ * the initial render — onSuccess fires after Compose has already cached the
+ * restored text, so without this the warning would never appear.
+ */
+@Composable
+private fun rememberRestoredText(text: String, role: MessageRole): String {
+    val riVersion = OpenObscureManager.riVersion.intValue
+    return remember(text, riVersion) {
+        if (role == MessageRole.ASSISTANT) {
+            val restored = OpenObscureManager.restore(text)
+            // Check if the cognitive firewall flagged this message
+            val warning = OpenObscureManager.getRiWarning(text)
+            if (warning != null) {
+                warning + restored
+            } else {
+                restored
+            }
+        } else {
+            text
+        }
+    }
